      <artifactId>gson</artifactId>
      <version>2.12.1</version>
    </dependency>
    <dependency>
      <groupId>com.j256.two-factor-auth</groupId>
      <artifactId>two-factor-auth</artifactId>
      <version>1.3</version>
    </dependency>
    <!-- commons-csv removed: CSV parsing inlined as MiscUtils.parseExcelCsv() -->
    <!-- commons-text removed: LevenshteinDistance inlined as MiscUtils.levenshtein() -->
    <dependency>
      <groupId>com.formdev</groupId>
      <artifactId>flatlaf</artifactId>
      <version>3.5.4</version>
    </dependency>
    <dependency>
      <groupId>com.github.lostromb.concentus</groupId>
      <artifactId>Concentus</artifactId>
      <version>${concentus.version}</version>
    </dependency>
    <dependency>
      <groupId>net.java.dev.jna</groupId>
      <artifactId>jna</artifactId>
      <version>${jna.version}</version>
    </dependency>
    <dependency>
      <groupId>net.java.dev.jna</groupId>
      <artifactId>jna-platform</artifactId>
      <version>${jna.version}</version>
    </dependency>
    <!-- DAVE/E2EE Protocol Support -->
    <dependency>
      <groupId>moe.kyokobot.libdave</groupId>
      <artifactId>libdave-jvm-adapter-jda</artifactId>
      <version>${libdave.version}</version>
    </dependency>
    <dependency>
      <groupId>moe.kyokobot.libdave</groupId>
      <artifactId>libdave-jvm-impl</artifactId>
      <version>${libdave.version}</version>
    </dependency>
    <!-- Android/Termux JNI natives for Discord voice E2EE. Kept in the
         default build so plain `mvn package` preserves the Termux use-case
         instead of silently dropping DAVE support on rebuild. -->
    <dependency>
      <groupId>moe.kyokobot.libdave</groupId>
      <artifactId>libdave-jvm-natives-android</artifactId>
      <version>${libdave.version}</version>
    </dependency>
    <!-- Native libraries for DAVE - Linux x86-64 (glibc 2.28+) -->
    <dependency>
      <groupId>moe.kyokobot.libdave</groupId>
      <artifactId>natives-linux-x86-64</artifactId>
      <version>${libdave.native.version}</version>
    </dependency>
    <!-- Native libraries for DAVE - Windows x86-64 -->
    <dependency>
      <groupId>moe.kyokobot.libdave</groupId>
      <artifactId>natives-win-x86-64</artifactId>
      <version>${libdave.native.version}</version>
    </dependency>
    <!-- Native libraries for DAVE - macOS (Universal) -->
    <dependency>
      <groupId>moe.kyokobot.libdave</groupId>
      <artifactId>natives-darwin</artifactId>
      <version>${libdave.native.version}</version>
    </dependency>
    <!-- jsr305 removed: @Nullable annotations replaced with comments in source -->
