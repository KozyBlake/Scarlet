<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/scarlet_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/scarlet_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/hero_subtitle"
            android:textColor="@color/scarlet_text_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/pairSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pair_section_title"
                android:textColor="@color/scarlet_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/pair_prompt_body"
                android:textColor="@color/scarlet_text_muted"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/pairCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card_alt"
                android:digits="0123456789"
                android:hint="@string/pair_code_hint"
                android:inputType="number"
                android:maxLength="6"
                android:padding="14dp"
                android:textColor="@color/scarlet_text"
                android:textColorHint="@color/scarlet_text_dim" />

            <EditText
                android:id="@+id/pairPortInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card_alt"
                android:hint="@string/pair_port_hint"
                android:inputType="text"
                android:maxLines="1"
                android:padding="14dp"
                android:singleLine="true"
                android:textColor="@color/scarlet_text"
                android:textColorHint="@color/scarlet_text_dim" />

            <Button
                android:id="@+id/pairButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_primary"
                android:padding="14dp"
                android:text="@string/pair_button"
                android:textColor="@color/scarlet_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dashboardSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_title"
                    android:textColor="@color/scarlet_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dashboardIntro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/connect_prompt_body"
                    android:textColor="@color/scarlet_text_muted"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_card_alt"
                    android:padding="14dp"
                    android:textColor="@color/scarlet_text"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/connectButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_button_primary"
                    android:padding="14dp"
                    android:text="@string/connect_button"
                    android:textColor="@color/scarlet_text" />

                <TextView
                    android:id="@+id/batteryStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/scarlet_text_muted" />

                <Button
                    android:id="@+id/batteryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_secondary"
                    android:padding="14dp"
                    android:text="@string/battery_button"
                    android:textColor="@color/scarlet_text" />

                <Button
                    android:id="@+id/resetButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_secondary"
                    android:padding="14dp"
                    android:text="@string/reset_button"
                    android:textColor="@color/scarlet_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/session_title"
                    android:textColor="@color/scarlet_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/accountSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/scarlet_text_muted"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/locationSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/scarlet_text_muted"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/playerCountSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/scarlet_text_muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/players_title"
                    android:textColor="@color/scarlet_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/playerListEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/player_list_empty"
                    android:textColor="@color/scarlet_text_muted"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/player_list_columns"
                    android:textColor="@color/scarlet_text_dim"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/playerListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
