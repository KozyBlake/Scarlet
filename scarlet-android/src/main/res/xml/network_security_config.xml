<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext/loopback traffic to 127.0.0.1 so libadb-android can open
  raw TCP sockets to the on-device adbd before its application-layer TLS
  handshake takes over.  Android's NetworkSecurityConfig only sees the
  underlying TCP, not the in-protocol TLS, so this opt-in is required even
  for the Wireless Debugging path.  Everything else stays at the platform
  default (no cleartext to the outside world).
  -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
